apiVersion: v1
kind: Secret
metadata:
  name: kafka-creds
  namespace: kafka-cluster
type: Opaque
stringData:
  credentials: |
    {
      "brokers": [
        "kafka-0.kafka-headless:9093",
        "kafka-1.kafka-headless:9093",
        "kafka-2.kafka-headless:9093"
      ],
      "tls": {
        "insecureSkipVerify": false,
        "clientCertificatePath": {
          "certFile": "/etc/certs/tls.crt",
          "keyFile": "/etc/certs/tls.key"
        }
      }
    }
# The certificate files must be accessible on the filesystem where the provider
# runs. A common pattern is to mount a Kubernetes Secret or a cert-manager
# Certificate as a volume in the provider's Pod and point certFile/keyFile to
# the mounted paths.
